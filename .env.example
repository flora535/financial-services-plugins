# Required for SEC EDGAR requests (use your email or app contact in this string)
SEC_USER_AGENT="free-sec-edgar-mcp/1.0 (your-email@example.com)"

# Optional but recommended for stable usage
FRED_API_KEY=
TWELVEDATA_API_KEY=
ALPHAVANTAGE_API_KEY=
MASSIVE_API_KEY=

# Optional for IBKR asset monitor MCP (ib_async + TWS/IB Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=101
IBKR_TIMEOUT_SECONDS=8
IBKR_READ_ONLY=true
ASSET_MONITOR_OFFLINE_PATH=financial-analysis/data/offline-assets.json
